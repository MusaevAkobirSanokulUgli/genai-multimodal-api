# Copy this file to .env and fill in your values.
# All variables use the GENAI_ prefix.

# OpenAI API key (required for real AI calls)
GENAI_OPENAI_API_KEY=sk-your-api-key-here

# Model overrides (optional)
GENAI_DEFAULT_LLM=gpt-4o
GENAI_DEFAULT_VISION_MODEL=gpt-4o
GENAI_DEFAULT_IMAGE_MODEL=dall-e-3
GENAI_DEFAULT_TTS_MODEL=tts-1
GENAI_DEFAULT_STT_MODEL=whisper-1

# Concurrency
GENAI_MAX_CONCURRENT_REQUESTS=10
GENAI_REQUEST_TIMEOUT=120

# Moderation
GENAI_MODERATION_ENABLED=true
GENAI_MODERATION_THRESHOLD=0.5  # Threshold for flagging (sensitive_info score is 0.6)

# Debug mode
GENAI_DEBUG=false
